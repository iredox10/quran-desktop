{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "http:default",
    "fs:default",
    "fs:allow-applocaldata-read-recursive",
    "fs:allow-applocaldata-write-recursive",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-write-file",
    "notification:default",
    "store:default",
    "updater:default"
  ]
}
